# Copy to .env and fill in.  ->  cp .env.example .env

# REQUIRED. Generate with: openssl rand -base64 32
SESSION_SECRET=change-me-generate-with-openssl-rand-base64-32

# Invite code required to sign up. STRONGLY recommended on a public URL (e.g.
# Tailscale Funnel), since otherwise anyone can register — and the first signup
# becomes admin. Share it with teammates. Generate with: openssl rand -hex 4
# Leave empty to allow open signup (fine for local/trusted networks only).
REGISTRATION_CODE=

# --- Outbound email (email verification + password reset) -------------------
# Leave SMTP_HOST empty to run WITHOUT email: signup then skips verification and
# password reset is unavailable (pre-0.32 behaviour). Any SMTP submission service
# works (Brevo free tier recommended: smtp-relay.brevo.com, port 587).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# From-address shown to recipients (must be allowed by your SMTP provider):
MAIL_FROM=
# Public base URL used in emailed links (your Funnel URL / domain):
APP_URL=

# Host port the app is published on (localhost). Point Tailscale Funnel or your
# reverse proxy at this. Any unprivileged port works under rootless Docker.
APP_PORT=3000
# Bind address for the published port. Keep 127.0.0.1 when fronted by Funnel /
# a proxy on the same host; set 0.0.0.0 to reach it directly on your LAN.
APP_BIND=127.0.0.1

# --- Only needed if you use the optional Caddy profile (not with Funnel) ---
# Your public domain for automatic HTTPS:
APP_DOMAIN=localhost
# Override if rootless Docker can't bind 80/443 (e.g. 8080 / 8443):
HTTP_PORT=80
HTTPS_PORT=443

# For LOCAL (non-Docker) dev only — Docker sets these itself:
# DATABASE_URL=file:./dev.db
