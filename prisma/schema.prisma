// UWR Trainer — data model.
// Note: SQLite does not support Prisma enums, so "enum-like" fields are stored as
// String and validated in the app via Zod/TS unions (see src/lib/constants.ts).

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

/// A team member. role: "PLAYER" | "TRAINER" | "ADMIN". locale: "en" | "de".
/// email + passwordHash are nullable: a row with passwordHash = NULL is an account-less
/// roster member (created by a trainer; can be "claimed" at signup, keeping history).
model User {
  id               String   @id @default(cuid())
  email            String?  @unique
  name             String
  passwordHash     String?
  role             String   @default("PLAYER")
  activeTeamId     String?
  locale           String   @default("en")
  availabilityNote String?
  trainerNote      String?
  // Per-user rest-timer prefs (strength logger). Durations are seconds; 0 is allowed via the UI
  // but the master switch is restTimerEnabled.
  restTimerEnabled  Boolean @default(true)
  restTimerBeep     Boolean @default(true)
  restTimerVibrate  Boolean @default(true)
  restWarmupSeconds Int     @default(75)
  restMainSeconds   Int     @default(150)
  restBbbSeconds    Int     @default(90)
  // Per-user planned-weight rounding for the strength plan/logger.
  // "EXACT" | "DOWN" (Wendler default) | "NEAREST" | "UP", to weightIncrement kg.
  weightRounding    String  @default("DOWN")
  weightIncrement   Float   @default(2.5)
  // Per-user strength-logging prefs: warm-up ramp (JSON [{pct,reps}], whole-number percents)
  // and the "Boring But Big" assistance set (JSON {pct,reps}). NULL = built-in defaults.
  strengthWarmup    String?
  strengthBbb       String?
  // Optional pull slots in the strength plan: vertical (pull-ups) / horizontal (rows).
  strengthPullups   Boolean @default(true)
  strengthRows      Boolean @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  plans            Plan[]            @relation("PlanOwner")
  createdPlans     Plan[]            @relation("PlanCreator")
  sessionLogs      SessionLog[]
  strengthPrograms StrengthProgram[]
  memberships      TeamMembership[]
}

/// A team. registrationCode gates self-signup/join for this team. The migration creates a
/// default team (id "team-default"); when its code is NULL the env REGISTRATION_CODE applies.
model Team {
  id               String   @id @default(cuid())
  name             String
  registrationCode String?
  createdAt        DateTime @default(now())

  memberships   TeamMembership[]
  practiceSlots PracticeSlot[]
}

/// User <-> Team many-to-many. A user's active team is User.activeTeamId (fallback: first membership).
model TeamMembership {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  teamId    String
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, teamId])
  @@index([teamId])
}

/// Team-wide recurring practice. tier: "PRIMARY" (mandatory) | "SECONDARY" | "OPTIONAL".
model PracticeSlot {
  id        String   @id @default(cuid())
  teamId    String   @default("team-default")
  team      Team     @relation(fields: [teamId], references: [id])
  label     String
  dayOfWeek Int // 0=Sun .. 6=Sat
  time      String? // "19:00"
  tier      String   @default("SECONDARY")
  // Manual availability toggle: false = paused/hidden (not loggable, no auto-miss), independent
  // of the seasonal window below. active AND in-window => the practice is bookable that day.
  active    Boolean  @default(true)
  // Optional seasonal window (calendar dates, inclusive by day; null = open-ended). Outside it the
  // practice isn't offered for logging and generates no auto-miss — for summer/winter schedules.
  validFrom DateTime?
  validTo   DateTime?
  createdAt DateTime @default(now())

  planItems   PlanItem[]
  sessionLogs SessionLog[]
}

/// A player's agreed plan, versioned by validFrom/validTo (plans are revised ~monthly).
model Plan {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation("PlanOwner", fields: [userId], references: [id], onDelete: Cascade)
  validFrom   DateTime  @default(now())
  validTo     DateTime?
  createdById String?
  createdBy   User?     @relation("PlanCreator", fields: [createdById], references: [id])
  createdAt   DateTime  @default(now())

  items PlanItem[]

  @@index([userId])
}

/// One commitment within a plan. category: "RUGBY" | "STRENGTH" | "CARDIO" | "MOBILITY".
/// For RUGBY, practiceSlotId points at the specific team practice committed to.
model PlanItem {
  id                String        @id @default(cuid())
  planId            String
  plan              Plan          @relation(fields: [planId], references: [id], onDelete: Cascade)
  category          String
  practiceSlotId    String?
  practiceSlot      PracticeSlot? @relation(fields: [practiceSlotId], references: [id])
  targetPerWeek     Int           @default(1)
  targetDurationMin Int?
  note              String?

  @@index([planId])
}

/// A logged training session. status: "DONE" | "MISSED". details holds type-specific
/// JSON (strength sets/reps/weight, cardio zone, etc.) as a stringified payload.
model SessionLog {
  id             String        @id @default(cuid())
  userId         String
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  date           DateTime
  category       String
  status         String        @default("DONE")
  durationMin    Int?
  missReason     String?
  practiceSlotId String?
  practiceSlot   PracticeSlot? @relation(fields: [practiceSlotId], references: [id])
  details        String? // JSON string
  auto           Boolean       @default(false) // true = auto-generated MISSED entry (see lib/missed.ts)
  // true once this session has advanced its lifts' per-movement waves (finishStrengthWorkout).
  // Guards against double-advancing when a finished workout is re-finished or edited.
  progressionApplied Boolean   @default(false)
  createdAt      DateTime      @default(now())

  @@index([userId, date])
  @@index([date])
}

/// Configurable leaderboard. Multiple can be enabled at once.
/// metric: "ADHERENCE_POINTS" | "RUGBY_PRACTICES" | "PRIMARY_PRACTICES" | "STREAK".
/// visibility: "TRAINERS_ONLY" | "EVERYONE".
model Leaderboard {
  id         String  @id @default(cuid())
  metric     String  @unique
  title      String
  enabled    Boolean @default(false)
  visibility String  @default("TRAINERS_ONLY")
  sortOrder  Int     @default(0)
}

/// A player's Wendler-style strength program (see src/lib/strength.ts).
/// equipment: top-level choice "WEIGHTS" | "BODYWEIGHT" (preselects defaults).
/// `movements` holds the per-movement state ({ trainingMax?, repMax?, levelIndex?, holds? })
/// as a JSON string, shared across all slots/days. `days` is JSON
/// [{ id, name, minutes, slots: [{ movement, exerciseId, mode, tool, custom? }] }].
/// cycle/week are the LEGACY shared pointer — now a fallback seed only. Progression is
/// PER MOVEMENT: each lift carries its own `week`/`cycle` (+ holds/pendingAmrap/deloadReset/
/// lastTrainedAt) inside the movements JSON and advances on its own when logged. The program
/// cycle/week are read only until a lift first advances. consecutiveHolds is legacy (kept 0);
/// mode is legacy too (written as "CUSTOM").
model StrengthProgram {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  mode             String
  equipment        String   @default("NONE")
  daysPerWeek      Int      @default(2)
  minutesPerSession Int     @default(45)
  trainingMaxPct   Float    @default(0.9)
  rounding         Float    @default(2.5)
  movements        String // JSON: per-movement state { trainingMax?, repMax?, levelIndex?, exercise ids }
  days             String   @default("[]") // JSON: [{ id, name, equipment, minutes }] — per-day setup
  weightedLayout   String   @default("ROTATE") // single-weighted-day layout: ROTATE | ALL_IN_ONE
  notes            String? // free-text plan notes for trainers to see
  cycle            Int      @default(1)
  week             Int      @default(1)
  consecutiveHolds Int      @default(0)
  active           Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([userId])
}

/// Generic key/value app settings (team name, scoring overrides, etc.).
model Setting {
  key   String @id
  value String
}
